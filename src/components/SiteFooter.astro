---
import { siteConfig } from '../config/site';

const year = new Date().getFullYear();

const footerLinks = [
  { href: '/about/', label: 'About the Club' },
  { href: '/age-groups/', label: 'Age Groups' },
  { href: '/leagues/', label: 'Leagues' },
  { href: '/sponsors/', label: 'Sponsors' },
  { href: '/blog/', label: 'Blog' },
  { href: '/new-sponsors/', label: 'Become a Sponsor' },
  { href: '/contact/', label: 'Contact Us' },
];
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <p class="footer-name">Fusion FC</p>
      <p class="footer-tagline">
        Community-first football pathways for players, families, and local partners across the region.
      </p>
      <div class="footer-badge">Est. 2024</div>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">Quick Links</h3>
      <ul class="footer-nav">
        {footerLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">Get in Touch</h3>
      <div class="footer-contact-list">
        <div class="footer-contact-item">
          <span class="contact-label">Email</span>
          <a href={`mailto:${siteConfig.clubContactEmail}`}>{siteConfig.clubContactEmail}</a>
        </div>
        <div class="footer-contact-item">
          <span class="contact-label">Phone</span>
          <span>{siteConfig.clubPhone}</span>
        </div>
      </div>
      <a href="/new-sponsors/" class="footer-cta">Sponsor the Club →</a>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© {year} Fusion Football Club. All rights reserved.</p>
    <p class="footer-placeholder-note">Update contact details before go-live.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-2xl);
    background: var(--color-charcoal);
    color: var(--color-paper);
    padding: var(--space-2xl) 0 0;
  }

  .footer-inner {
    width: min(1120px, 92vw);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1.2fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid rgba(245, 247, 246, 0.1);
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-lime);
    margin-bottom: 0.7rem;
  }

  .footer-tagline {
    color: rgba(245, 247, 246, 0.55);
    font-size: 0.92rem;
    line-height: 1.6;
    max-width: 28ch;
    margin-bottom: 1.2rem;
  }

  .footer-badge {
    display: inline-flex;
    border: 1px solid rgba(29, 185, 84, 0.3);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(29, 185, 84, 0.75);
  }

  .footer-heading {
    font-family: var(--font-display);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(245, 247, 246, 0.35);
    margin: 0 0 var(--space-s);
  }

  .footer-nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }

  .footer-nav a {
    color: rgba(245, 247, 246, 0.7);
    font-size: 0.9rem;
    transition: color var(--transition);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .footer-nav a::before {
    content: '';
    width: 14px;
    height: 1px;
    background: rgba(29, 185, 84, 0.4);
    flex-shrink: 0;
    transition: width var(--transition), background var(--transition);
  }

  .footer-nav a:hover {
    color: var(--color-lime);
  }

  .footer-nav a:hover::before {
    width: 20px;
    background: var(--color-lime);
  }

  .footer-contact-list {
    display: grid;
    gap: 0.9rem;
    margin-bottom: var(--space-m);
  }

  .footer-contact-item {
    display: grid;
    gap: 0.18rem;
  }

  .contact-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(245, 247, 246, 0.35);
  }

  .footer-contact-item a,
  .footer-contact-item span {
    color: rgba(245, 247, 246, 0.78);
    font-size: 0.9rem;
    transition: color var(--transition);
  }

  .footer-contact-item a:hover {
    color: var(--color-lime);
  }

  .footer-cta {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(29, 185, 84, 0.35);
    border-radius: 999px;
    padding: 0.55rem 1.1rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-lime);
    transition: background var(--transition), border-color var(--transition);
  }

  .footer-cta:hover {
    background: rgba(29, 185, 84, 0.1);
    border-color: rgba(29, 185, 84, 0.65);
  }

  .footer-bottom {
    width: min(1120px, 92vw);
    margin: 0 auto;
    padding: var(--space-m) 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
  }

  .footer-bottom p {
    font-size: 0.78rem;
    color: rgba(245, 247, 246, 0.3);
  }

  .footer-placeholder-note {
    font-style: italic;
  }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer-inner {
      width: min(95vw, 95vw);
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      width: min(95vw, 95vw);
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-nav a,
    .footer-nav a::before,
    .footer-contact-item a,
    .footer-cta {
      transition: none;
    }
  }
</style>
