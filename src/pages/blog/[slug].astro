---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createBlogPostingJsonLd, createBreadcrumbJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ data }) => !data.draft);

  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props as Props;
const { Content } = await render(entry);

// Estimated reading time
const wordCount = entry.body.split(/\s+/).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const breadcrumbs = createBreadcrumbJsonLd([
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog/' },
  { name: entry.data.title, path: `/blog/${entry.id}/` }
]);

const articleSchema = createBlogPostingJsonLd({
  title: entry.data.title,
  description: entry.data.seoDescription ?? entry.data.excerpt,
  slug: entry.id,
  publishedTime: entry.data.date.toISOString(),
  modifiedTime: entry.data.updatedDate?.toISOString(),
  image: entry.data.ogImage ?? entry.data.coverImage
});

const formattedDate = entry.data.date.toLocaleDateString('en-GB', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric'
});
---

<BaseLayout
  title={entry.data.seoTitle ?? entry.data.title}
  description={entry.data.seoDescription ?? entry.data.excerpt}
  canonical={entry.data.canonicalUrl ?? `/blog/${entry.id}/`}
  image={entry.data.ogImage ?? entry.data.coverImage}
  type="article"
  publishedTime={entry.data.date.toISOString()}
  modifiedTime={entry.data.updatedDate?.toISOString()}
  noindex={entry.data.noindex}
  structuredData={[breadcrumbs, articleSchema]}
>
  <!-- Reading progress bar -->
  <div class="reading-progress" aria-hidden="true">
    <div class="reading-bar" id="reading-bar"></div>
  </div>

  <article>
    <section class="page-hero reveal">
      <p class="eyebrow">Fusion Blog</p>
      <h1 class="hero-title">{entry.data.title}</h1>
      <p class="hero-summary">{entry.data.excerpt}</p>
      <div class="article-meta">
        <time class="meta-date" datetime={entry.data.date.toISOString()}>{formattedDate}</time>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span class="meta-author">{entry.data.author}</span>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span class="meta-read">{readingTime} min read</span>
      </div>
      {entry.data.tags.length > 0 && (
        <div class="chip-list article-hero-tags">
          {entry.data.tags.map((tag) => <span class="chip">{tag}</span>)}
        </div>
      )}
    </section>

    <section class="dark-band article-band reveal" data-delay="1" id="article-body">
      <img
        src={entry.data.coverImage}
        alt={entry.data.title}
        class="article-cover"
      />

      <div class="prose article-prose">
        <Content />
      </div>

      <div class="article-footer">
        <div class="footer-row">
          <a class="back-link" href="/blog/">← Back to blog</a>
          <button class="copy-btn" id="copy-link" type="button" aria-label="Copy link to this post">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <span class="copy-label">Copy link</span>
          </button>
        </div>
      </div>
    </section>
  </article>

  <!-- Scroll to top -->
  <button class="scroll-top" id="scroll-top" type="button" aria-label="Back to top">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg>
  </button>
</BaseLayout>

<style>
  /* ─── Reading progress bar ───────────────────────────── */

  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 100;
    pointer-events: none;
  }

  .reading-bar {
    height: 100%;
    width: 0%;
    background: var(--color-lime);
    box-shadow: 0 0 10px rgba(29, 185, 84, 0.6);
    transition: width 0.08s linear;
  }

  /* ─── Hero meta ──────────────────────────────────────── */

  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-m);
    font-size: 0.88rem;
    color: rgba(245, 247, 246, 0.55);
  }

  .meta-sep { color: rgba(245, 247, 246, 0.2); }

  .meta-read {
    font-family: var(--font-display);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-lime);
  }

  .article-hero-tags {
    margin-top: var(--space-s);
  }

  /* ─── Article band ───────────────────────────────────── */

  .article-band {
    padding: 0;
    overflow: hidden;
  }

  .article-cover {
    width: 100%;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    display: block;
  }

  .article-prose {
    padding: var(--space-l) var(--space-xl);
    max-width: 72ch;
  }

  /* ─── Prose enhancements ─────────────────────────────── */

  /* Blockquotes — dramatic pull-quote style */
  .article-prose :global(blockquote) {
    position: relative;
    margin: var(--space-l) 0;
    padding: var(--space-m) var(--space-l);
    border-left: 3px solid var(--color-lime);
    background: rgba(29, 185, 84, 0.05);
    border-radius: 0 var(--radius-s) var(--radius-s) 0;
  }

  .article-prose :global(blockquote)::before {
    content: '\201C';
    position: absolute;
    top: -0.6rem;
    left: var(--space-m);
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 1;
    color: rgba(29, 185, 84, 0.2);
    pointer-events: none;
  }

  .article-prose :global(blockquote p) {
    font-size: 1.08rem;
    font-style: italic;
    color: rgba(245, 247, 246, 0.85);
    line-height: 1.65;
  }

  /* Section headings — lime left tick */
  .article-prose :global(h2),
  .article-prose :global(h3) {
    position: relative;
    padding-left: var(--space-m);
  }

  .article-prose :global(h2)::before,
  .article-prose :global(h3)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.2em;
    bottom: 0.2em;
    width: 3px;
    background: var(--color-lime);
    border-radius: 2px;
  }

  /* ─── Article footer ─────────────────────────────────── */

  .article-footer {
    padding: var(--space-m) var(--space-xl) var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    flex-wrap: wrap;
  }

  .back-link {
    font-size: 0.88rem;
    color: rgba(245, 247, 246, 0.4);
    font-weight: 600;
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--color-lime);
  }

  /* ─── Copy link button ───────────────────────────────── */

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(29, 185, 84, 0.08);
    border: 1px solid rgba(29, 185, 84, 0.25);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(245, 247, 246, 0.6);
    cursor: pointer;
    transition: background var(--transition), border-color var(--transition), color var(--transition);
  }

  .copy-btn:hover {
    background: rgba(29, 185, 84, 0.14);
    border-color: rgba(29, 185, 84, 0.5);
    color: var(--color-lime);
  }

  .copy-btn.copied {
    background: rgba(29, 185, 84, 0.18);
    border-color: var(--color-lime);
    color: var(--color-lime);
  }

  /* ─── Scroll to top ──────────────────────────────────── */

  .scroll-top {
    position: fixed;
    bottom: var(--space-l);
    right: var(--space-l);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-lime);
    color: var(--color-ink);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(12px) scale(0.9);
    transition: opacity 0.3s, transform 0.3s, background var(--transition);
    z-index: 50;
    pointer-events: none;
  }

  .scroll-top.visible {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }

  .scroll-top:hover {
    background: var(--color-lime-bright);
    transform: translateY(-2px);
  }

  /* ─── Prose element stagger (applied via JS) ─────────── */

  :global(.prose-item) {
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  :global(.prose-item.prose-hidden) {
    opacity: 0;
    transform: translateY(14px);
  }

  /* ─── Responsive ─────────────────────────────────────── */

  @media (max-width: 720px) {
    .article-prose,
    .article-footer {
      padding-left: var(--space-m);
      padding-right: var(--space-m);
    }

    .scroll-top {
      bottom: var(--space-m);
      right: var(--space-m);
    }
  }
</style>

<script>
  declare const gtag: (...args: unknown[]) => void;

  /* ─── Reading progress ───────────────────────────────── */
  const bar = document.getElementById('reading-bar');
  const articleBody = document.getElementById('article-body');

  if (bar && articleBody) {
    const depthFired = new Set<number>();
    const updateProgress = () => {
      const top = articleBody.getBoundingClientRect().top + window.scrollY;
      const progress = Math.min(Math.max((window.scrollY - top) / articleBody.offsetHeight, 0), 1);
      bar.style.width = `${progress * 100}%`;
      [25, 50, 75, 100].forEach((milestone) => {
        if (!depthFired.has(milestone) && progress * 100 >= milestone) {
          depthFired.add(milestone);
          if (typeof gtag !== 'undefined') {
            gtag('event', 'scroll_depth', {
              event_category: 'Blog',
              event_label: document.title,
              percent_scrolled: milestone
            });
          }
        }
      });
    };
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }

  /* ─── Scroll-to-top button ───────────────────────────── */
  const scrollBtn = document.getElementById('scroll-top');
  if (scrollBtn) {
    window.addEventListener('scroll', () => {
      scrollBtn.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });
    scrollBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }

  /* ─── Copy link button ───────────────────────────────── */
  const copyBtn = document.getElementById('copy-link');
  if (copyBtn) {
    const label = copyBtn.querySelector('.copy-label');
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyBtn.classList.add('copied');
        if (label) label.textContent = 'Copied!';
        if (typeof gtag !== 'undefined') {
          gtag('event', 'share', { method: 'copy_link', content_type: 'blog_post', item_id: window.location.pathname });
        }
        setTimeout(() => {
          copyBtn.classList.remove('copied');
          if (label) label.textContent = 'Copy link';
        }, 2000);
      } catch {
        // Clipboard not available — silently ignore
      }
    });
  }

  /* ─── Staggered prose element reveals ───────────────── */
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const proseEl = document.querySelector('.article-prose');
    if (proseEl) {
      const items = Array.from(proseEl.children);
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.remove('prose-hidden');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -24px 0px' }
      );

      items.forEach((el, i) => {
        el.classList.add('prose-item', 'prose-hidden');
        (el as HTMLElement).style.transitionDelay = `${Math.min(i * 0.05, 0.3)}s`;
        observer.observe(el);
      });
    }
  }
</script>
