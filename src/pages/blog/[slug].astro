---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createBlogPostingJsonLd, createBreadcrumbJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ data }) => !data.draft);

  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props as Props;
const { Content } = await render(entry);

// Related posts — most recent other posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((p) => p.id !== entry.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const breadcrumbs = createBreadcrumbJsonLd([
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog/' },
  { name: entry.data.title, path: `/blog/${entry.id}/` }
]);

const articleSchema = createBlogPostingJsonLd({
  title: entry.data.title,
  description: entry.data.seoDescription ?? entry.data.excerpt,
  slug: entry.id,
  publishedTime: entry.data.date.toISOString(),
  modifiedTime: entry.data.updatedDate?.toISOString(),
  image: entry.data.ogImage ?? entry.data.coverImage
});

const formattedDate = entry.data.date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<BaseLayout
  title={entry.data.seoTitle ?? entry.data.title}
  description={entry.data.seoDescription ?? entry.data.excerpt}
  canonical={entry.data.canonicalUrl ?? `/blog/${entry.id}/`}
  image={entry.data.ogImage ?? entry.data.coverImage}
  type="article"
  publishedTime={entry.data.date.toISOString()}
  modifiedTime={entry.data.updatedDate?.toISOString()}
  noindex={entry.data.noindex}
  structuredData={[breadcrumbs, articleSchema]}
>
  <!-- Reading progress bar -->
  <div class="reading-progress" aria-hidden="true">
    <div class="reading-bar" id="reading-bar"></div>
  </div>

  <article>
    <!-- Cinematic hero with cover image background -->
    <header class="article-hero reveal">
      <div class="article-hero-media">
        <img
          src={entry.data.coverImage}
          alt=""
          class="article-hero-img"
          aria-hidden="true"
        />
        <div class="article-hero-overlay"></div>
      </div>

      <div class="article-hero-content">
        <a class="article-eyebrow" href="/blog/">← Fusion Blog</a>
        <h1 class="article-title">{entry.data.title}</h1>
        <p class="article-excerpt">{entry.data.excerpt}</p>
        <div class="article-meta">
          <time datetime={entry.data.date.toISOString()}>{formattedDate}</time>
          <span class="meta-dot" aria-hidden="true">·</span>
          <span>{entry.data.author}</span>
          {entry.data.tags.length > 0 && (
            <>
              <span class="meta-dot" aria-hidden="true">·</span>
              <div class="meta-tags">
                {entry.data.tags.map((tag) => (
                  <span class="chip chip-sm">{tag}</span>
                ))}
              </div>
            </>
          )}
        </div>
      </div>
    </header>

    <!-- Article body -->
    <section class="dark-band article-body reveal" data-delay="1" id="article-body">
      <div class="prose article-prose">
        <Content />
      </div>

      <!-- Footer: back link + related posts -->
      <footer class="article-footer">
        <a class="back-link" href="/blog/">← Back to all posts</a>

        {relatedPosts.length > 0 && (
          <div class="related-posts">
            <p class="related-heading">More from the blog</p>
            <div class="related-grid">
              {relatedPosts.map((post) => (
                <a class="related-card" href={`/blog/${post.id}/`}>
                  <img
                    src={post.data.coverImage}
                    alt={post.data.title}
                    class="related-img"
                  />
                  <div class="related-body">
                    <time class="related-date">
                      {post.data.date.toLocaleDateString('en-GB', {
                        day: 'numeric',
                        month: 'short',
                        year: 'numeric'
                      })}
                    </time>
                    <p class="related-title">{post.data.title}</p>
                    <p class="related-excerpt">{post.data.excerpt}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </footer>
    </section>
  </article>
</BaseLayout>

<style>
  /* ─── Reading progress bar ───────────────────────────── */

  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 100;
    background: rgba(255, 255, 255, 0.06);
    pointer-events: none;
  }

  .reading-bar {
    height: 100%;
    width: 0%;
    background: var(--color-lime);
    transition: width 0.08s linear;
    box-shadow: 0 0 8px rgba(29, 185, 84, 0.6);
  }

  /* ─── Article hero ───────────────────────────────────── */

  .article-hero {
    margin-top: var(--space-m);
    position: relative;
    min-height: 520px;
    border-radius: var(--radius-l);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3.5rem);
  }

  .article-hero-media {
    position: absolute;
    inset: 0;
  }

  .article-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.04);
    transition: transform 8s ease;
  }

  .article-hero:hover .article-hero-img {
    transform: scale(1);
  }

  /* Dark gradient overlay — heavier at bottom for legibility */
  .article-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(8, 10, 10, 0.15) 0%,
      rgba(8, 10, 10, 0.45) 45%,
      rgba(8, 10, 10, 0.92) 100%
    );
  }

  /* Lime diagonal accent, echoes the global hero */
  .article-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      118deg,
      transparent 0%,
      transparent 55%,
      rgba(2, 93, 36, 0.35) 100%
    );
    pointer-events: none;
  }

  .article-hero-content {
    position: relative;
    z-index: 1;
    max-width: 72ch;
  }

  .article-eyebrow {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-lime);
    margin-bottom: var(--space-s);
    transition: opacity var(--transition);
  }

  .article-eyebrow:hover {
    opacity: 0.75;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.5vw, 3.2rem);
    color: var(--color-paper);
    line-height: 1.12;
    letter-spacing: 0.01em;
    margin-bottom: var(--space-s);
    text-wrap: balance;
  }

  .article-excerpt {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    color: rgba(245, 247, 246, 0.72);
    line-height: 1.6;
    max-width: 58ch;
    margin-bottom: var(--space-m);
  }

  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    font-size: 0.84rem;
    color: rgba(245, 247, 246, 0.5);
  }

  .meta-dot {
    color: rgba(245, 247, 246, 0.2);
  }

  .meta-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .chip-sm {
    font-size: 0.65rem;
    padding: 0.15rem 0.5rem;
  }

  /* ─── Article body ───────────────────────────────────── */

  .article-body {
    padding: var(--space-xl);
  }

  .article-prose {
    max-width: 72ch;
  }

  /* ─── Article footer ─────────────────────────────────── */

  .article-footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-l);
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .back-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: rgba(245, 247, 246, 0.4);
    transition: color var(--transition);
    width: fit-content;
  }

  .back-link:hover {
    color: var(--color-lime);
  }

  /* ─── Related posts ──────────────────────────────────── */

  .related-heading {
    font-family: var(--font-display);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-lime);
    margin-bottom: var(--space-m);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-m);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-top: 2px solid rgba(29, 185, 84, 0.25);
    border-radius: var(--radius-m);
    overflow: hidden;
    transition: border-top-color var(--transition), background var(--transition), transform var(--transition);
  }

  .related-card:hover {
    border-top-color: var(--color-lime);
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-3px);
  }

  .related-img {
    width: 100%;
    aspect-ratio: 16 / 6;
    object-fit: cover;
    display: block;
  }

  .related-body {
    padding: var(--space-s) var(--space-m) var(--space-m);
    display: grid;
    gap: 0.3rem;
  }

  .related-date {
    font-family: var(--font-display);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-lime);
  }

  .related-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-paper);
    line-height: 1.3;
  }

  .related-excerpt {
    font-size: 0.82rem;
    color: rgba(245, 247, 246, 0.45);
    line-height: 1.5;
  }

  /* ─── Responsive ─────────────────────────────────────── */

  @media (max-width: 720px) {
    .article-hero {
      min-height: 420px;
    }

    .article-body {
      padding: var(--space-m);
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Reading progress bar
  const bar = document.getElementById('reading-bar');
  const body = document.getElementById('article-body');

  if (bar && body) {
    const update = () => {
      const top = body.getBoundingClientRect().top + window.scrollY;
      const scrolled = window.scrollY - top;
      const progress = Math.min(Math.max(scrolled / body.offsetHeight, 0), 1);
      bar.style.width = `${progress * 100}%`;
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
