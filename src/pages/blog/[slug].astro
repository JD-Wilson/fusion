---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createBlogPostingJsonLd, createBreadcrumbJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ data }) => !data.draft);

  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props as Props;
const { Content } = await render(entry);

const breadcrumbs = createBreadcrumbJsonLd([
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog/' },
  { name: entry.data.title, path: `/blog/${entry.id}/` }
]);

const articleSchema = createBlogPostingJsonLd({
  title: entry.data.title,
  description: entry.data.seoDescription ?? entry.data.excerpt,
  slug: entry.id,
  publishedTime: entry.data.date.toISOString(),
  modifiedTime: entry.data.updatedDate?.toISOString(),
  image: entry.data.ogImage ?? entry.data.coverImage
});

const formattedDate = entry.data.date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<BaseLayout
  title={entry.data.seoTitle ?? entry.data.title}
  description={entry.data.seoDescription ?? entry.data.excerpt}
  canonical={entry.data.canonicalUrl ?? `/blog/${entry.id}/`}
  image={entry.data.ogImage ?? entry.data.coverImage}
  type="article"
  publishedTime={entry.data.date.toISOString()}
  modifiedTime={entry.data.updatedDate?.toISOString()}
  noindex={entry.data.noindex}
  structuredData={[breadcrumbs, articleSchema]}
>
  <!-- Reading progress bar -->
  <div class="reading-progress" aria-hidden="true">
    <div class="reading-bar" id="reading-bar"></div>
  </div>

  <article>
    <!-- Hero: same pattern as the rest of the site -->
    <section class="page-hero reveal">
      <p class="eyebrow">Fusion Blog</p>
      <h1 class="hero-title">{entry.data.title}</h1>
      <p class="hero-summary">{entry.data.excerpt}</p>
      <div class="article-meta">
        <time class="meta-date" datetime={entry.data.date.toISOString()}>{formattedDate}</time>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span class="meta-author">{entry.data.author}</span>
      </div>
      {entry.data.tags.length > 0 && (
        <div class="chip-list article-hero-tags">
          {entry.data.tags.map((tag) => <span class="chip">{tag}</span>)}
        </div>
      )}
    </section>

    <!-- Article content: dark band, consistent with rest of site -->
    <section class="dark-band article-band reveal" data-delay="1" id="article-body">
      <img
        src={entry.data.coverImage}
        alt={entry.data.title}
        class="article-cover"
      />

      <div class="prose article-prose">
        <Content />
      </div>

      <div class="article-footer">
        <a class="back-link" href="/blog/">← Back to blog</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  /* ─── Reading progress bar ───────────────────────────── */

  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 100;
    pointer-events: none;
  }

  .reading-bar {
    height: 100%;
    width: 0%;
    background: var(--color-lime);
    box-shadow: 0 0 8px rgba(29, 185, 84, 0.5);
    transition: width 0.08s linear;
  }

  /* ─── Hero meta ──────────────────────────────────────── */

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-m);
    font-size: 0.88rem;
    color: rgba(245, 247, 246, 0.55);
  }

  .meta-sep {
    color: rgba(245, 247, 246, 0.2);
  }

  .article-hero-tags {
    margin-top: var(--space-s);
  }

  /* ─── Article band ───────────────────────────────────── */

  .article-band {
    padding: 0;
    overflow: hidden;
  }

  .article-cover {
    width: 100%;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    display: block;
  }

  .article-prose {
    padding: var(--space-l) var(--space-xl);
    max-width: 72ch;
  }

  /* ─── Article footer ─────────────────────────────────── */

  .article-footer {
    padding: var(--space-m) var(--space-xl) var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .back-link {
    font-size: 0.88rem;
    color: rgba(245, 247, 246, 0.4);
    font-weight: 600;
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--color-lime);
  }

  /* ─── Responsive ─────────────────────────────────────── */

  @media (max-width: 720px) {
    .article-prose,
    .article-footer {
      padding-left: var(--space-m);
      padding-right: var(--space-m);
    }
  }
</style>

<script>
  const bar = document.getElementById('reading-bar');
  const body = document.getElementById('article-body');

  if (bar && body) {
    const update = () => {
      const top = body.getBoundingClientRect().top + window.scrollY;
      const progress = Math.min(Math.max((window.scrollY - top) / body.offsetHeight, 0), 1);
      bar.style.width = `${progress * 100}%`;
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
