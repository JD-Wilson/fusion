---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createBlogPostingJsonLd, createBreadcrumbJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ data }) => !data.draft);

  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props as Props;
const { Content } = await render(entry);

const breadcrumbs = createBreadcrumbJsonLd([
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog/' },
  { name: entry.data.title, path: `/blog/${entry.id}/` }
]);

const articleSchema = createBlogPostingJsonLd({
  title: entry.data.title,
  description: entry.data.seoDescription ?? entry.data.excerpt,
  slug: entry.id,
  publishedTime: entry.data.date.toISOString(),
  modifiedTime: entry.data.updatedDate?.toISOString(),
  image: entry.data.ogImage ?? entry.data.coverImage
});
---

<BaseLayout
  title={entry.data.seoTitle ?? entry.data.title}
  description={entry.data.seoDescription ?? entry.data.excerpt}
  canonical={entry.data.canonicalUrl ?? `/blog/${entry.id}/`}
  image={entry.data.ogImage ?? entry.data.coverImage}
  type="article"
  publishedTime={entry.data.date.toISOString()}
  modifiedTime={entry.data.updatedDate?.toISOString()}
  noindex={entry.data.noindex}
  structuredData={[breadcrumbs, articleSchema]}
>
  <article>
    <section class="page-hero reveal">
      <p class="eyebrow">Fusion Blog</p>
      <h1 class="hero-title">{entry.data.title}</h1>
      <p class="hero-summary">{entry.data.excerpt}</p>
      <p class="article-meta">
        <span>{entry.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span>{entry.data.author}</span>
      </p>
    </section>

    <section class="dark-band article-band reveal" data-delay="1">
      <img src={entry.data.coverImage} alt={entry.data.title} class="article-cover" />

      {entry.data.tags.length > 0 && (
        <div class="chip-list article-tags">
          {entry.data.tags.map((tag) => <span class="chip">{tag}</span>)}
        </div>
      )}

      <div class="prose article-prose">
        <Content />
      </div>

      <div class="article-footer">
        <a class="back-link" href="/blog/">← Back to blog</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.9rem;
    font-size: 0.88rem;
    color: rgba(245, 247, 246, 0.6);
  }

  .meta-sep {
    color: rgba(245, 247, 246, 0.25);
  }

  .article-band {
    padding: 0;
    overflow: hidden;
  }

  .article-cover {
    width: 100%;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    display: block;
  }

  .article-tags {
    padding: var(--space-m) var(--space-xl) 0;
  }

  .article-prose {
    padding: var(--space-m) var(--space-xl);
    max-width: 72ch;
  }

  .article-footer {
    padding: var(--space-m) var(--space-xl) var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .back-link {
    font-size: 0.88rem;
    color: rgba(245, 247, 246, 0.4);
    font-weight: 600;
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--color-lime);
  }

  @media (max-width: 720px) {
    .article-tags,
    .article-prose,
    .article-footer {
      padding-left: var(--space-m);
      padding-right: var(--space-m);
    }
  }
</style>
