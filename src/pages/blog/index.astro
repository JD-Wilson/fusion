---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { createBreadcrumbJsonLd } from '../../lib/seo';
import { requirePageEntry } from '../../lib/pages';

const blogPage = await requirePageEntry('blog');
const { Content } = await render(blogPage);

const posts = (await getCollection('blog', ({ data }) => !data.draft && !data.noindex)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const breadcrumbs = createBreadcrumbJsonLd([
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog/' }
]);
---

<BaseLayout
  title={blogPage.data.seoTitle ?? blogPage.data.title}
  description={blogPage.data.seoDescription ?? blogPage.data.description}
  canonical={blogPage.data.canonicalUrl ?? '/blog/'}
  image={blogPage.data.ogImage}
  noindex={blogPage.data.noindex}
  structuredData={[breadcrumbs]}
>
  <PageHero eyebrow="Club Updates" title={blogPage.data.title} summary={blogPage.data.description} />

  <section class="section-card reveal" data-delay="1">
    <div class="prose">
      <Content />
    </div>
  </section>

  <section class="dark-band reveal" data-delay="2">
    <div class="band-head">
      <div>
        <p class="band-eyebrow">Latest Posts</p>
        <h2 class="band-title">Club Updates</h2>
      </div>
    </div>

    <div class="posts-grid">
      {posts.map((post) => (
        <article class="dark-card post-card">
          <a href={`/blog/${post.id}/`} class="post-cover-link" tabindex="-1" aria-hidden="true">
            <img src={post.data.coverImage} alt="" class="post-cover" />
          </a>
          <div class="post-body">
            <p class="post-date">{post.data.date.toLocaleDateString('en-GB')}</p>
            <h2 class="post-title">
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h2>
            <p class="post-excerpt">{post.data.excerpt}</p>
            {post.data.tags.length > 0 && (
              <div class="chip-list">
                {post.data.tags.map((tag) => <span class="chip">{tag}</span>)}
              </div>
            )}
            <a class="link-arrow" href={`/blog/${post.id}/`}>Read post</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-m);
  }

  .post-card {
    padding: 0;
    display: grid;
    align-content: start;
  }

  .post-cover-link {
    display: block;
  }

  .post-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-m) var(--radius-m) 0 0;
    display: block;
  }

  .post-body {
    padding: var(--space-m);
    display: grid;
    gap: 0.4rem;
    align-content: start;
  }

  .post-date {
    font-family: var(--font-display);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-lime);
  }

  .post-title {
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .post-title a {
    color: var(--color-paper);
    transition: color var(--transition);
  }

  .post-title a:hover {
    color: var(--color-lime);
  }

  .post-excerpt {
    font-size: 0.87rem;
    color: rgba(245, 247, 246, 0.55);
    line-height: 1.55;
  }

  @media (max-width: 920px) {
    .posts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 600px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
